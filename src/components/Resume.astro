---
---
<!-- RESUME SECTION -->
<section id="resume" class="py-24 bg-beige-dark min-h-screen">
    <div class="max-w-5xl mx-auto px-6 lg:px-12">
        
        <!-- Section Header -->
        <div class="flex items-center justify-center mb-16" data-aos="fade-up">
            <div class="w-5 h-5 bg-accent mr-4"></div>
            <h2 class="text-4xl font-bold">Resume</h2>
        </div>

        <!-- Sub-header & Action -->
        <div class="flex flex-col sm:flex-row justify-between items-center mb-8" data-aos="fade-up" data-aos-delay="100">
            <h3 class="text-2xl font-bold mb-4 sm:mb-0">Experience</h3>
            <a href="#" class="bg-accent text-white px-8 py-3 rounded-full font-medium text-sm hover:bg-blue-700 transition-colors shadow-md">DOWNLOAD CV</a>
        </div>

        <!-- Experience Card -->
        <article class="bg-white p-8 md:p-12 card-shadow" data-aos="fade-up" data-aos-delay="200">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                
                <!-- Left Col: Meta -->
                <div class="col-span-1 border-l-4 border-accent pl-4">
                    <p class="text-accent font-bold text-lg mb-1">2021 – Present</p>
                    <p class="font-bold text-ink uppercase tracking-wide text-sm mb-1">Senior Engineer</p>
                    <p class="text-gray-600 text-sm mb-1">Tech Solutions Inc.</p>
                    <p class="text-gray-400 text-sm">San Francisco, CA</p>
                </div>

                <!-- Right Col: Details (STAR Method) -->
                <div class="col-span-1 md:col-span-2 text-gray-600 leading-relaxed">
                    <p class="mb-4">Spearheaded the migration of a monolithic legacy application into a robust microservices architecture using Node.js and React. This reduced system latency by 40% and improved developer deployment times.</p>
                    <p>Collaborated cross-functionally with product and design teams to implement WCAG 2.1 compliant UI components, increasing accessibility scores and expanding the user base.</p>
                </div>
            </div>
        </article>

    </div>
</section>
