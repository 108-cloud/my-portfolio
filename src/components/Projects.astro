---
---
<!-- PROJECTS SECTION -->
<section id="projects" class="py-24 bg-beige-light min-h-screen">
    <div class="max-w-5xl mx-auto px-6 lg:px-12">
        
        <!-- Section Header -->
        <div class="flex items-center justify-center mb-8" data-aos="fade-up">
            <div class="w-5 h-5 bg-accent mr-4"></div>
            <h2 class="text-4xl font-bold">Projects</h2>
        </div>

        <p class="text-center text-gray-600 max-w-2xl mx-auto mb-16" data-aos="fade-up" data-aos-delay="100">
            A selection of recent work showcasing my technical approach, architectural decision-making, and focus on delivering business value through clean code.
        </p>

        <!-- Project Card -->
        <article class="bg-white flex flex-col md:flex-row card-shadow overflow-hidden group" data-aos="fade-up" data-aos-delay="200">
            
            <!-- Text Area -->
            <div class="p-8 md:p-12 md:w-1/2 flex flex-col justify-center border-l-8 border-transparent group-hover:border-accent transition-colors duration-300">
                <h3 class="text-accent font-bold text-2xl mb-1">Enterprise Analytics Dashboard</h3>
                <p class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-6">Lead Frontend Developer</p>
                <p class="text-gray-600 leading-relaxed">
                    Engineered a high-performance data visualization dashboard rendering 10k+ data points in real-time. Built with TypeScript, React, and D3.js. Optimized rendering cycles to maintain a strict 60FPS, resulting in a 35% increase in client engagement time.
                </p>
            </div>

            <!-- Image Area -->
            <div class="md:w-1/2 h-64 md:h-auto relative overflow-hidden">
                <img src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" 
                     alt="Data Dashboard Preview" 
                     class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                     loading="lazy">
            </div>
        </article>

    </div>
</section>
