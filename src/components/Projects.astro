<!-- 將此 Script 放在 HTML 內，Astro 會自動編譯並在 Client-side 執行 -->
<script>
    class ProjectCarousel extends HTMLElement {
        connectedCallback() {
            // 使用類型斷言 (Type Assertion) 告訴 TS 這些是 HTMLElement
            const track = this.querySelector(
                ".carousel-track",
            ) as HTMLElement | null;
            const nextBtn = this.querySelector(
                ".next-btn",
            ) as HTMLElement | null;
            const prevBtn = this.querySelector(
                ".prev-btn",
            ) as HTMLElement | null;
            const indicators = this.querySelectorAll(".indicator");

            // 1. 安全檢查：如果找不到必要元件，直接返回不執行，避免報錯
            if (!track || !nextBtn || !prevBtn) return;

            const slides = track.children;
            let currentIndex = 0;

            const updateCarousel = () => {
                // 2. 這裡 track 已經確定不是 null 了
                track.style.transform = `translateX(-${currentIndex * 100}%)`;

                indicators.forEach((ind, i) => {
                    const indicator = ind as HTMLElement; // 轉型以存取 classList
                    if (i === currentIndex) {
                        indicator.classList.remove("bg-white/50");
                        indicator.classList.add("bg-white");
                    } else {
                        indicator.classList.remove("bg-white");
                        indicator.classList.add("bg-white/50");
                    }
                });
            };

            // 3. 事件監聽
            nextBtn.addEventListener("click", (e) => {
                e.preventDefault();
                currentIndex = (currentIndex + 1) % slides.length;
                updateCarousel();
            });

            prevBtn.addEventListener("click", (e) => {
                e.preventDefault();
                currentIndex =
                    (currentIndex - 1 + slides.length) % slides.length;
                updateCarousel();
            });

            indicators.forEach((ind, i) => {
                ind.addEventListener("click", (e) => {
                    e.preventDefault();
                    currentIndex = i;
                    updateCarousel();
                });
            });
        }
    }

    if (!customElements.get("project-carousel")) {
        customElements.define("project-carousel", ProjectCarousel);
    }
</script>
