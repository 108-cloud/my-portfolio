---
import { Image } from 'astro:assets';
import profileImage from '../assets/images/profile.jpg';
---
<!-- ABOUT SECTION / HERO -->
<section id="about" class="relative pt-32 pb-24 min-h-[90vh] flex items-center bg-beige-light overflow-hidden">
    <!-- Decorative Left Background Block -->
    <div class="absolute top-0 left-0 w-full md:w-[40%] h-full bg-beige-dark z-0"></div>
    
    <div class="max-w-6xl mx-auto px-6 lg:px-12 relative z-10 w-full flex flex-col md:flex-row items-center gap-16 lg:gap-24">
        
        <!-- Left Card (Profile) -->
        <article class="bg-beige-light card-shadow w-full md:w-[400px] flex-shrink-0" data-aos="fade-up">
            <div class="p-10 flex flex-col items-center text-center">
                <div class="w-48 h-48 rounded-full overflow-hidden mb-6 border-4 border-white shadow-inner relative group">
                    <Image src={profileImage} 
                         alt="Ting-Wei Hu Profile Photo" 
                         class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                         loading="eager" />
                </div>
                <h2 class="text-3xl font-bold mb-2">Ting-Wei<br>Hu</h2>
                <div class="w-12 h-0.5 bg-accent my-4"></div>
                <p class="tracking-[0.2em] text-sm text-gray-500 font-light mb-8 uppercase">Software Engineer</p>
            </div>
            <!-- Social Bar -->
            <div class="bg-white flex justify-center gap-6 py-4 border-t border-gray-100">
                <a href="#" class="text-ink hover:text-accent transition-colors" aria-label="GitHub"><i class="fa-brands fa-github text-xl"></i></a>
                <a href="#" class="text-ink hover:text-accent transition-colors" aria-label="LinkedIn"><i class="fa-brands fa-linkedin text-xl"></i></a>
                <a href="#" class="text-ink hover:text-accent transition-colors" aria-label="Twitter"><i class="fa-brands fa-twitter text-xl"></i></a>
            </div>
        </article>

        <!-- Right Content (Intro) -->
        <article class="flex-1 text-center md:text-left" data-aos="fade-left" data-aos-delay="200">
            <h1 class="text-6xl md:text-8xl font-bold mb-6 tracking-tight">Hello</h1>
            <h3 class="text-xl md:text-2xl font-medium mb-8">Here's who I am & what I do</h3>
            
            <div class="flex flex-wrap justify-center md:justify-start gap-4 mb-8">
                <a href="#resume" class="bg-accent text-white px-8 py-3 rounded-full font-medium hover:bg-blue-700 hover:shadow-lg transition-all">RESUME</a>
                <a href="#projects" class="border-2 border-ink text-ink px-8 py-3 rounded-full font-medium hover:bg-ink hover:text-white transition-all">PROJECTS</a>
            </div>
            
            <div class="text-gray-600 leading-relaxed space-y-4 max-w-xl">
                <p>I am a detail-oriented Software Engineer with a passion for building scalable, high-performance web applications. I bridge the gap between complex engineering challenges and seamless user experiences.</p>
                <p>With expertise in modern JavaScript frameworks, system architecture, and agile methodologies, I thrive in environments where technology solves real-world business problems.</p>
            </div>
        </article>
    </div>
</section>
