---
import { Image } from "astro:assets";
import profileImage from "../assets/images/profile.png";
---

<!-- ABOUT SECTION / HERO -->
<section
    id="about"
    class="relative pt-32 pb-24 min-h-[90vh] flex items-center bg-beige-light overflow-hidden"
>
    <!-- Decorative Left Background Block -->
    <div
        class="absolute top-0 left-0 w-full md:w-[40%] h-full bg-beige-dark z-0"
    >
    </div>

    <div
        class="max-w-6xl mx-auto px-6 lg:px-12 relative z-10 w-full flex flex-col md:flex-row items-center gap-16 lg:gap-24"
    >
        <!-- Left Card (Profile) -->
        <article
            class="bg-beige-light card-shadow w-full md:w-[400px] flex-shrink-0"
            data-aos="fade-up"
        >
            <div class="p-10 flex flex-col items-center text-center">
                <div
                    class="w-48 h-48 rounded-full overflow-hidden mb-6 border-4 border-white shadow-inner relative group"
                >
                    <Image
                        src={profileImage}
                        alt="Ting-Wei Hu Profile Photo"
                        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                        loading="eager"
                    />
                </div>
                <h2 class="text-3xl font-bold mb-2">Ting-Wei<br />Hu</h2>
                <div class="w-12 h-0.5 bg-accent my-4"></div>
                <!-- Updated Professional Title -->
                <p
                    class="tracking-[0.2em] text-sm text-gray-500 font-light mb-8 uppercase text-center leading-relaxed"
                >
                    Translational<br />Researcher
                </p>
            </div>
            <!-- Social Bar -->
            <div
                class="bg-white flex justify-center gap-6 py-4 border-t border-gray-100"
            >
                <a
                    href="https://www.linkedin.com/in/ting-wei-hu"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-ink hover:text-accent transition-colors"
                    aria-label="LinkedIn"
                    ><i class="fa-brands fa-linkedin text-xl"></i></a
                >
            </div>
        </article>

        <!-- Right Content (Intro) -->
        <article
            class="flex-1 text-center md:text-left"
            data-aos="fade-left"
            data-aos-delay="200"
        >
            <h1 class="text-6xl md:text-8xl font-bold mb-6 tracking-tight">
                Hello
            </h1>
            <h3 class="text-xl md:text-2xl font-medium mb-8">
                Here's who I am & what I do
            </h3>

            <div
                class="flex flex-wrap justify-center md:justify-start gap-4 mb-8"
            >
                <a
                    href="#resume"
                    class="bg-accent text-white px-8 py-3 rounded-full font-medium hover:bg-blue-700 hover:shadow-lg transition-all"
                    >RESUME</a
                >
                <a
                    href="#projects"
                    class="border-2 border-ink text-ink px-8 py-3 rounded-full font-medium hover:bg-ink hover:text-white transition-all"
                    >PROJECTS</a
                >
            </div>

            <!-- Bilingual Summary Area -->
            <div class="text-gray-600 leading-relaxed space-y-5 max-w-xl">
                <!-- English Profile -->
                <p>
                    I am a Certified Medical Technologist and translational
                    researcher (MS, National Taiwan University) specializing in
                    lung cancer single-cell multi-omics and prognostic analysis.
                    I <strong
                        >bridge the critical gap between wet-lab operations and
                        dry-lab bioinformatics</strong
                    >.
                </p>
                <p>
                    With deep expertise in NCCN NSCLC Guidelines and ICH-GCP
                    compliance, I excel at <strong
                        >translating complex NGS data into actionable clinical
                        insights</strong
                    >. My research on the tumor microenvironment recently earned
                    the <strong
                        >Runner-up award at the 2025 Taiwan Joint Cancer
                        Conference (TJCC)</strong
                    >.
                </p>

                <!-- Visual Divider -->
                <div class="w-16 h-px bg-gray-300 mx-auto md:mx-0 my-4"></div>

                <!-- Traditional Chinese Profile -->
                <p class="text-[0.95rem] text-justify font-medium">
                    我是具備國家醫事檢驗師執照的轉譯醫學研究者，取得台大醫檢碩士學位。專長為肺癌單細胞多體學與臨床預後分析
                    (R/Python)，並擅長作為跨部門樞紐，<strong
                        >無縫串聯 Wet-lab 檢驗與 Dry-lab 生資團隊</strong
                    >。
                </p>
                <p class="text-[0.95rem] text-justify font-medium">
                    熟悉 NCCN 臨床指南與 ICH-GCP 規範，我致力於將<strong
                        >複雜的次世代基因定序 (NGS)
                        數據轉化為具臨床決策價值的洞見</strong
                    >。近期於早期肺癌腫瘤微環境之研究，更<strong
                        >榮獲 2025 台灣癌症年會 (TJCC) 轉譯組亞軍</strong
                    >。
                </p>
            </div>
        </article>
    </div>
</section>
